// =================== ADD MISSING ADMIN ROUTES ===================
Route::middleware(['auth', 'admin'])->prefix('admin')->name('admin.')->group(function () {
    
    // Trust System
    Route::get('/trust', function() {
        return view('admin.trust');
    })->name('trust.index');
    
    // Email Logs
    Route::get('/emails', function() {
        return view('admin.emails');
    })->name('emails.index');
    
    // Global SMTP
    Route::get('/smtp', function() {
        return view('admin.smtp');
    })->name('smtp.index');
    
    // Revenue
    Route::get('/revenue', function() {
        return view('admin.revenue');
    })->name('revenue.index');
    
    // License Actions
    Route::post('/licenses/bulk-generate', function() {
        $count = request('count', 10);
        $days = request('days', 30);
        
        try {
            for ($i = 0; $i < $count; $i++) {
                $licenseKey = 'INFIMAL-' . strtoupper(bin2hex(random_bytes(4))) . '-' . 
                             strtoupper(bin2hex(random_bytes(4))) . '-' . 
                             strtoupper(bin2hex(random_bytes(4))) . '-' . 
                             strtoupper(bin2hex(random_bytes(4)));
                
                DB::table('licenses')->insert([
                    'license_key' => $licenseKey,
                    'plan_type' => 'Premium',
                    'duration_days' => $days,
                    'is_active' => true,
                    'price' => 299.00,
                    'expires_at' => now()->addDays($days),
                    'created_at' => now(),
                    'updated_at' => now()
                ]);
            }
            
            return response()->json(['success' => true, 'message' => "$count licenses generated"]);
        } catch (\Exception $e) {
            return response()->json(['success' => false, 'message' => 'Error'], 500);
        }
    })->name('licenses.bulk-generate');
    
    Route::get('/licenses/export', function() {
        try {
            $licenses = DB::table('licenses')->get();
            $filename = 'licenses_export_' . date('Y-m-d') . '.csv';
            
            $headers = [
                'Content-Type' => 'text/csv',
                'Content-Disposition' => 'attachment; filename="' . $filename . '"',
            ];
            
            $callback = function() use ($licenses) {
                $file = fopen('php://output', 'w');
                fputcsv($file, ['License Key', 'Plan', 'Price', 'Expires', 'Created']);
                
                foreach ($licenses as $license) {
                    fputcsv($file, [
                        $license->license_key ?? '',
                        $license->plan_type ?? 'Premium',
                        '$' . ($license->price ?? '299.00'),
                        $license->expires_at ?? '',
                        $license->created_at ?? ''
                    ]);
                }
                
                fclose($file);
            };
            
            return response()->stream($callback, 200, $headers);
        } catch (\Exception $e) {
            return back()->with('error', 'Export failed');
        }
    })->name('licenses.export');
    
    Route::post('/licenses/{id}/activate', function($id) {
        DB::table('licenses')->where('id', $id)->update(['is_active' => true]);
        return response()->json(['success' => true]);
    })->name('licenses.activate');
    
    Route::post('/licenses/{id}/suspend', function($id) {
        DB::table('licenses')->where('id', $id)->update(['is_active' => false]);
        return response()->json(['success' => true]);
    })->name('licenses.suspend');
    
    Route::post('/licenses/generate', function() {
        $licenseKey = 'INFIMAL-' . strtoupper(bin2hex(random_bytes(4))) . '-' . 
                     strtoupper(bin2hex(random_bytes(4))) . '-' . 
                     strtoupper(bin2hex(random_bytes(4))) . '-' . 
                     strtoupper(bin2hex(random_bytes(4)));
        
        DB::table('licenses')->insert([
            'license_key' => $licenseKey,
            'plan_type' => 'Premium',
            'duration_days' => 30,
            'is_active' => true,
            'price' => 299.00,
            'expires_at' => now()->addDays(30),
            'created_at' => now(),
            'updated_at' => now()
        ]);
        
        return response()->json(['success' => true, 'license_key' => $licenseKey]);
    })->name('licenses.generate');
});

