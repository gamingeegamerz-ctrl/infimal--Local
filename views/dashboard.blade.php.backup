    <script>
        // Real Analytics Manager
        class RealAnalytics {
            constructor() {
                this.charts = {};
            }

            // Initialize real charts
            initializeCharts() {
                // Subscriber Growth Chart
                const subscriberCtx = document.getElementById('subscriberChart').getContext('2d');
                
                this.charts.subscriber = new Chart(subscriberCtx, {
                    type: 'line',
                    data: {
                        labels: @json($growthLabels),
                        datasets: [{
                            label: 'New Subscribers',
                            data: @json($growthData),
                            borderColor: '#2b7cee',
                            backgroundColor: 'rgba(43, 124, 238, 0.1)',
                            tension: 0.4,
                            fill: true
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: {
                            legend: {
                                labels: { color: 'white' }
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                ticks: { color: 'white' },
                                grid: { color: 'rgba(255,255,255,0.1)' }
                            },
                            x: {
                                ticks: { color: 'white' },
                                grid: { color: 'rgba(255,255,255,0.1)' }
                            }
                        }
                    }
                });

                // Engagement Chart
                const engagementCtx = document.getElementById('engagementChart').getContext('2d');
                this.charts.engagement = new Chart(engagementCtx, {
                    type: 'doughnut',
                    data: {
                        labels: ['Opens', 'Clicks', 'No Engagement'],
                        datasets: [{
                            data: [
                                {{ $totalOpens }},
                                {{ $totalClicks }},
                                {{ max(0, $totalSubscribers - $totalOpens) }}
                            ],
                            backgroundColor: ['#2b7cee', '#a855f7', '#374151'],
                            borderWidth: 0
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: {
                            legend: {
                                position: 'bottom',
                                labels: { color: 'white' }
                            }
                        }
                    }
                });
            }

            // Simulate real-time data updates
            startLiveUpdates() {
                setInterval(() => {
                    this.updateLiveStats();
                }, 30000); // Update every 30 seconds
            }

            async updateLiveStats() {
                try {
                    const response = await fetch('/api/dashboard-stats');
                    const data = await response.json();
                    
                    // Update live stats
                    document.getElementById('emailsToday').textContent = data.emailsToday;
                    document.getElementById('opensToday').textContent = data.opensToday;
                    document.getElementById('clicksToday').textContent = data.clicksToday;
                    document.getElementById('activeCampaigns').textContent = data.activeCampaigns;
                    
                    console.log('Live stats updated at:', data.updated_at);
                } catch (error) {
                    console.log('Error updating live stats:', error);
                }
            }
        }

        // Initialize everything
        document.addEventListener('DOMContentLoaded', function() {
            const analytics = new RealAnalytics();
            analytics.initializeCharts();
            analytics.startLiveUpdates();
        });

        // Button functions
        function addSubscriber() {
            window.location.href = "{{ route('subscribers.create') }}";
        }

        function createCampaign() {
            window.location.href = "{{ route('campaigns.create') }}";
        }
    </script>
