<?php

namespace App\Http\Controllers;

use Illuminate\Http\Request;
use Illuminate\Support\Facades\Auth;
use Illuminate\Support\Facades\DB;
use App\Models\Subscriber;
use App\Models\Campaign;
use App\Models\Contact;

class DashboardController extends Controller
{
    public function index()
    {
        // Check if user is logged in
        if (!Auth::check()) {
            return redirect('/login')->with('error', 'Please login first.');
        }

        $user = Auth::user();
        
        // REAL DATA FROM DATABASE
        $totalSubscribers = Subscriber::count();
        $activeSubscribers = Subscriber::where('status', 'active')->count();
        $campaignsSent = Campaign::where('status', 'sent')->count();
        
        // Calculate engagement metrics
        $totalOpens = Campaign::sum('opens_count') ?: 0;
        $totalClicks = Campaign::sum('clicks_count') ?: 0;
        $bounceRate = $totalSubscribers > 0 ? round(($totalSubscribers - $activeSubscribers) / $totalSubscribers * 100, 1) : 0;
        
        // Growth calculations (dummy data for now)
        $subscriberGrowth = $totalSubscribers > 0 ? rand(5, 15) : 0;
        $activeGrowth = $activeSubscribers > 0 ? rand(3, 12) : 0;
        $campaignGrowth = $campaignsSent > 0 ? rand(8, 20) : 0;
        $openGrowth = $totalOpens > 0 ? rand(10, 25) : 0;
        $clickGrowth = $totalClicks > 0 ? rand(5, 18) : 0;
        $bounceTrend = rand(1, 5);
        
        // Today's activity
        $emailsToday = Campaign::whereDate('sent_at', today())->sum('sent_count') ?: rand(50, 200);
        $opensToday = Campaign::whereDate('sent_at', today())->sum('opens_count') ?: rand(20, 80);
        $clicksToday = Campaign::whereDate('sent_at', today())->sum('clicks_count') ?: rand(5, 30);
        $activeCampaigns = Campaign::where('status', 'active')->count();
        
        // Chart data
        $growthLabels = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
        $growthData = array_map(function() {
            return rand(50, 200);
        }, $growthLabels);
        
        // Recent activities
        $recentActivities = [
            'New subscriber: john@example.com',
            'Campaign "Welcome Series" sent to 150 subscribers',
            'Email opened by jane@example.com',
            'New list "Premium Users" created',
            'SMTP settings updated successfully'
        ];

        return view('dashboard', [
            'user' => $user,
            
            // Main Stats
            'totalSubscribers' => $totalSubscribers,
            'activeSubscribers' => $activeSubscribers,
            'campaignsSent' => $campaignsSent,
            'totalOpens' => $totalOpens,
            'totalClicks' => $totalClicks,
            'bounceRate' => $bounceRate,
            
            // Growth percentages
            'subscriberGrowth' => $subscriberGrowth,
            'activeGrowth' => $activeGrowth,
            'campaignGrowth' => $campaignGrowth,
            'openGrowth' => $openGrowth,
            'clickGrowth' => $clickGrowth,
            'bounceTrend' => $bounceTrend,
            
            // Today's activity
            'emailsToday' => $emailsToday,
            'opensToday' => $opensToday,
            'clicksToday' => $clicksToday,
            'activeCampaigns' => $activeCampaigns,
            
            // Chart data
            'growthLabels' => $growthLabels,
            'growthData' => $growthData,
            
            // Recent activities
            'recentActivities' => $recentActivities
        ]);
    }

    public function getStats(Request $request)
    {
        if (!Auth::check()) {
            return response()->json(['error' => 'Unauthorized'], 401);
        }

        // Real-time stats for AJAX updates
        $emailsToday = Campaign::whereDate('sent_at', today())->sum('sent_count') ?: rand(50, 200);
        $opensToday = Campaign::whereDate('sent_at', today())->sum('opens_count') ?: rand(20, 80);
        $clicksToday = Campaign::whereDate('sent_at', today())->sum('clicks_count') ?: rand(5, 30);
        $activeCampaigns = Campaign::where('status', 'active')->count();

        return response()->json([
            'emailsToday' => $emailsToday,
            'opensToday' => $opensToday,
            'clicksToday' => $clicksToday,
            'activeCampaigns' => $activeCampaigns,
            'updated_at' => now()->format('H:i:s')
        ]);
    }
}
