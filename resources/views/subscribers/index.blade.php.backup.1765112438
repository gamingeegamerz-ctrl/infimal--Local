    <!-- Import Modal -->
    <div id="importModal" class="fixed inset-0 bg-black/70 z-50 hidden items-center justify-center p-4">
        <div class="glass-card rounded-xl p-6 w-full max-w-2xl soft-shadow max-h-[90vh] overflow-y-auto">
            <div class="flex justify-between items-center mb-6">
