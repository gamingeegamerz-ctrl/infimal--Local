                                    <a href="{{ $url }}" class="px-3 py-2 bg-white/10 text-white hover:bg-white/20 rounded-lg transition-colors">{{ $page }}</a>
                                    @endif
                                @endforeach
                                
                                @if($subscribers->hasMorePages())
                                <a href="{{ $subscribers->nextPageUrl() }}" class="px-3 py-2 bg-white/10 text-white hover:bg-white/20 rounded-lg transition-colors">Next</a>
                                @else
                                <span class="px-3 py-2 bg-white/5 text-white/30 rounded-lg cursor-not-allowed">Next</span>
                                @endif
                            </div>
                        </div>
                        @endif
                    </div>
                </div>
            </main>
        </div>
    </div>

