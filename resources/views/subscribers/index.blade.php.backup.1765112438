    <!-- Subscriber Details Modal -->
    <div id="detailsModal" class="fixed inset-0 bg-black/70 z-50 hidden items-center justify-center p-4">
        <div class="glass-card rounded-xl p-6 w-full max-w-md soft-shadow max-h-[90vh] overflow-y-auto">
            <div class="flex justify-between items-center mb-6">
                <h3 class="text-white text-lg font-bold">Subscriber Details</h3>
                <button onclick="closeModal('detailsModal')" class="text-white/60 hover:text-white">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            <div id="detailsContent" class="space-y-4">
                <!-- Details will be loaded here -->
            </div>
        </div>
    </div>

    <!-- JavaScript -->
    <script>
        // REAL ANALYTICS CHARTS
        document.addEventListener('DOMContentLoaded', function() {
            // Growth Chart
            const growthCtx = document.getElementById('growthChart').getContext('2d');
            new Chart(growthCtx, {
                type: 'line',
                data: {
                    labels: @json($growthLabels),
                    datasets: [{
                        label: 'New Subscribers',
                        data: @json($growthData),
                        borderColor: '#2b7cee',
                        backgroundColor: 'rgba(43, 124, 238, 0.1)',
                        tension: 0.4,
                        fill: true
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: {
                            labels: { color: 'white' }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: { color: 'white' },
                            grid: { color: 'rgba(255,255,255,0.1)' }
                        },
                        x: {
                            ticks: { color: 'white' },
                            grid: { color: 'rgba(255,255,255,0.1)' }
                        }
                    }
                }
            });

            // Status Distribution Chart
            const statusCtx = document.getElementById('statusChart').getContext('2d');
            new Chart(statusCtx, {
                type: 'doughnut',
                data: {
                    labels: ['Active', 'Unsubscribed', 'Bounced'],
                    datasets: [{
                        data: [
                            {{ $activeSubscribers ?? 0 }},
                            {{ $unsubscribedCount }},
                            {{ $bouncedCount }}
                        ],
                        backgroundColor: ['#22c55e', '#eab308', '#ef4444'],
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: { color: 'white' }
                        }
                    }
                }
            });
        });

        // MODAL FUNCTIONS
        function showAddModal() {
            document.getElementById('addModal').classList.remove('hidden');
            document.getElementById('addModal').classList.add('flex');
            document.getElementById('addForm').reset();
            document.getElementById('saveButtonText').textContent = 'Add Subscriber';
        }

        function showImportModal() {
            document.getElementById('importModal').classList.remove('hidden');
            document.getElementById('importModal').classList.add('flex');
        }

        function closeModal(modalId) {
            document.getElementById(modalId).classList.add('hidden');
            document.getElementById(modalId).classList.remove('flex');
        }

        // SAVE SUBSCRIBER
        async function saveSubscriber(event) {
            event.preventDefault();
            
            const formData = new FormData(event.target);
            const submitBtn = event.target.querySelector('button[type="submit"]');
            const spinner = document.getElementById('saveSpinner');
            const buttonText = document.getElementById('saveButtonText');
            
            submitBtn.disabled = true;
            spinner.classList.remove('hidden');
            buttonText.textContent = 'Saving...';
            
            try {
                const response = await fetch('{{ route("subscribers.store") }}', {
                    method: 'POST',
                    headers: {
                        'X-CSRF-TOKEN': '{{ csrf_token() }}',
                        'Accept': 'application/json',
                    },
                    body: formData
                });
                
                const data = await response.json();
                
                if (response.ok) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Success!',
                        text: data.message || 'Subscriber added successfully!',
                        timer: 2000,
                        showConfirmButton: false
                    });
                    
                    setTimeout(() => {
                        location.reload();
                    }, 2000);
                } else {
                    throw new Error(data.message || 'Failed to save subscriber');
                }
            } catch (error) {
                Swal.fire({
                    icon: 'error',
                    title: 'Error!',
                    text: error.message
                });
            } finally {
                submitBtn.disabled = false;
                spinner.classList.add('hidden');
                buttonText.textContent = 'Add Subscriber';
            }
        }

        // IMPORT SUBSCRIBERS
        async function importSubscribers(event) {
            event.preventDefault();
            
            const formData = new FormData();
            const fileInput = document.getElementById('csvFile');
            const emailsText = document.getElementById('emailsText').value;
            const submitBtn = event.target.querySelector('button[type="submit"]');
            const spinner = document.getElementById('importSpinner');
            
            if (fileInput.files[0]) {
                formData.append('file', fileInput.files[0]);
            } else if (emailsText.trim()) {
                formData.append('emails', emailsText);
            } else {
                Swal.fire({
                    icon: 'warning',
                    title: 'No Data',
                    text: 'Please upload a file or enter email addresses'
                });
                return;
            }
            
            submitBtn.disabled = true;
            spinner.classList.remove('hidden');
            
            try {
                const response = await fetch('{{ route("subscribers.import") }}', {
                    method: 'POST',
                    headers: {
                        'X-CSRF-TOKEN': '{{ csrf_token() }}',
                    },
                    body: formData
                });
                
                const data = await response.json();
                
                if (response.ok) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Import Complete!',
                        html: `
                            <div class="text-left">
                                <p>✅ Imported: ${data.imported || 0} subscribers</p>
                                <p>⚠️ Skipped: ${data.skipped || 0} duplicates/invalid</p>
                                ${data.errors && data.errors.length ? 
                                    `<p class="text-red-400 mt-2">Errors:<br>${data.errors.slice(0, 3).join('<br>')}</p>` : ''}
                            </div>
                        `,
                        showConfirmButton: true
                    });
                    
                    setTimeout(() => {
                        location.reload();
                    }, 3000);
                } else {
                    throw new Error(data.message || 'Import failed');
                }
            } catch (error) {
                Swal.fire({
                    icon: 'error',
                    title: 'Import Failed',
                    text: error.message
                });
            } finally {
                submitBtn.disabled = false;
                spinner.classList.add('hidden');
            }
        }

        // HANDLE FILE SELECTION
        function handleFileSelect(event) {
            const file = event.target.files[0];
            const fileName = document.getElementById('fileName');
            
            if (file) {
                fileName.textContent = `Selected: ${file.name} (${(file.size / 1024).toFixed(2)} KB)`;
                fileName.classList.remove('hidden');
            }
        }

        // BULK ACTIONS
        let selectedSubscribers = new Set();

        document.getElementById('selectAll').addEventListener('change', function(e) {
            const checkboxes = document.querySelectorAll('.subscriber-checkbox');
            checkboxes.forEach(cb => {
                cb.checked = e.target.checked;
                if (e.target.checked) {
                    selectedSubscribers.add(cb.value);
                } else {
                    selectedSubscribers.delete(cb.value);
                }
            });
            updateBulkActions();
        });

        document.querySelectorAll('.subscriber-checkbox').forEach(cb => {
            cb.addEventListener('change', function() {
                if (this.checked) {
                    selectedSubscribers.add(this.value);
                } else {
                    selectedSubscribers.delete(this.value);
                }
                updateBulkActions();
            });
        });

        function updateBulkActions() {
            const bulkActions = document.getElementById('bulkActions');
            const selectedCount = document.getElementById('selectedCount');
            
            if (selectedSubscribers.size > 0) {
                bulkActions.style.display = 'block';
                selectedCount.textContent = selectedSubscribers.size;
            } else {
                bulkActions.style.display = 'none';
            }
        }

        function showBulkActions() {
            const dropdown = document.getElementById('bulkDropdown');
            dropdown.classList.toggle('hidden');
            
            // Close on click outside
            document.addEventListener('click', function closeDropdown(e) {
                if (!dropdown.contains(e.target) && !document.querySelector('#bulkActions button').contains(e.target)) {
                    dropdown.classList.add('hidden');
                    document.removeEventListener('click', closeDropdown);
                }
            });
        }

        async function bulkUpdateStatus(status) {
            if (selectedSubscribers.size === 0) return;
            
            const result = await Swal.fire({
                title: 'Update Status?',
                text: `Mark ${selectedSubscribers.size} subscriber(s) as ${status}?`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Yes, update',
                cancelButtonText: 'Cancel'
            });
            
            if (result.isConfirmed) {
                try {
                    const response = await fetch('{{ route("subscribers.bulk-update") }}', {
                        method: 'POST',
                        headers: {
                            'X-CSRF-TOKEN': '{{ csrf_token() }}',
                            'Content-Type': 'application/json',
                            'Accept': 'application/json'
                        },
                        body: JSON.stringify({
                            ids: Array.from(selectedSubscribers),
                            status: status
                        })
                    });
                    
                    const data = await response.json();
                    
                    if (response.ok) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Updated!',
                            text: data.message || 'Status updated successfully'
                        });
                        
                        setTimeout(() => {
                            location.reload();
                        }, 1500);
                    } else {
                        throw new Error(data.message || 'Update failed');
                    }
                } catch (error) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: error.message
                    });
                }
            }
        }

        async function bulkDelete() {
            if (selectedSubscribers.size === 0) return;
            
            const result = await Swal.fire({
                title: 'Delete Subscribers?',
                text: `This will permanently delete ${selectedSubscribers.size} subscriber(s). This action cannot be undone.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Yes, delete',
                cancelButtonText: 'Cancel',
                confirmButtonColor: '#ef4444'
            });
            
            if (result.isConfirmed) {
                try {
                    const response = await fetch('{{ route("subscribers.bulk-delete") }}', {
                        method: 'POST',
                        headers: {
                            'X-CSRF-TOKEN': '{{ csrf_token() }}',
                            'Content-Type': 'application/json',
                            'Accept': 'application/json'
                        },
                        body: JSON.stringify({
                            ids: Array.from(selectedSubscribers)
                        })
                    });
                    
                    const data = await response.json();
                    
                    if (response.ok) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Deleted!',
                            text: data.message || 'Subscribers deleted successfully'
                        });
                        
                        setTimeout(() => {
                            location.reload();
                        }, 1500);
                    } else {
                        throw new Error(data.message || 'Delete failed');
                    }
                } catch (error) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: error.message
                    });
                }
            }
        }

        // EDIT SUBSCRIBER
        async function editSubscriber(id) {
            try {
                const response = await fetch(`/subscribers/${id}/edit`);
                const html = await response.text();
                
                // Create edit modal with form
                const editModal = document.createElement('div');
                editModal.id = 'editModal';
                editModal.className = 'fixed inset-0 bg-black/70 z-50 flex items-center justify-center p-4';
                editModal.innerHTML = html;
                document.body.appendChild(editModal);
                
                // Handle edit form submission
                const form = editModal.querySelector('form');
                form.onsubmit = async function(e) {
                    e.preventDefault();
                    await updateSubscriber(id, new FormData(form));
                };
            } catch (error) {
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'Failed to load edit form'
                });
            }
        }

        async function updateSubscriber(id, formData) {
            try {
                const response = await fetch(`/subscribers/${id}`, {
                    method: 'PUT',
                    headers: {
                        'X-CSRF-TOKEN': '{{ csrf_token() }}',
                        'Accept': 'application/json'
                    },
                    body: formData
                });
                
                const data = await response.json();
                
                if (response.ok) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Updated!',
                        text: data.message || 'Subscriber updated successfully'
                    });
                    
                    setTimeout(() => {
                        location.reload();
                    }, 1500);
                } else {
                    throw new Error(data.message || 'Update failed');
                }
            } catch (error) {
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: error.message
                });
            }
        }

        // DELETE SUBSCRIBER
        async function deleteSubscriber(id) {
            const result = await Swal.fire({
                title: 'Delete Subscriber?',
                text: 'This action cannot be undone.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Yes, delete',
                cancelButtonText: 'Cancel',
                confirmButtonColor: '#ef4444'
            });
            
            if (result.isConfirmed) {
                try {
                    const response = await fetch(`/subscribers/${id}`, {
                        method: 'DELETE',
                        headers: {
                            'X-CSRF-TOKEN': '{{ csrf_token() }}',
                            'Accept': 'application/json'
                        }
                    });
                    
                    const data = await response.json();
                    
                    if (response.ok) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Deleted!',
                            text: data.message || 'Subscriber deleted successfully'
                        });
                        
                        setTimeout(() => {
                            location.reload();
                        }, 1500);
                    } else {
                        throw new Error(data.message || 'Delete failed');
                    }
                } catch (error) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: error.message
                    });
                }
            }
        }

        // SHOW SUBSCRIBER DETAILS
        async function showSubscriberDetails(id) {
            try {
                const response = await fetch(`/subscribers/${id}/details`);
                const data = await response.json();
                
                if (response.ok) {
                    const detailsContent = document.getElementById('detailsContent');
                    detailsContent.innerHTML = `
                        <div class="space-y-4">
                            <div class="flex items-center gap-3">
                                <div class="w-12 h-12 rounded-full bg-primary/20 flex items-center justify-center">
                                    <span class="material-symbols-outlined text-primary">person</span>
                                </div>
                                <div>
                                    <h4 class="text-white font-bold text-lg">${data.name || 'N/A'}</h4>
                                    <p class="text-white/70">${data.email}</p>
                                </div>
                            </div>
                            
                            <div class="grid grid-cols-2 gap-4">
                                <div>
                                    <p class="text-white/50 text-sm">Status</p>
                                    <p class="text-white font-medium">${data.status.charAt(0).toUpperCase() + data.status.slice(1)}</p>
                                </div>
                                <div>
                                    <p class="text-white/50 text-sm">Location</p>
                                    <p class="text-white font-medium">${data.location || 'Not set'}</p>
                                </div>
                                <div>
                                    <p class="text-white/50 text-sm">Opens</p>
                                    <p class="text-white font-medium">${data.opens_count}</p>
                                </div>
                                <div>
                                    <p class="text-white/50 text-sm">Clicks</p>
                                    <p class="text-white font-medium">${data.clicks_count}</p>
                                </div>
                            </div>
                            
                            <div>
                                <p class="text-white/50 text-sm">Subscribed</p>
                                <p class="text-white font-medium">${new Date(data.subscribed_at).toLocaleDateString()} • ${new Date(data.subscribed_at).toLocaleTimeString()}</p>
                            </div>
                            
                            ${data.tags && data.tags.length ? `
                            <div>
                                <p class="text-white/50 text-sm">Tags</p>
                                <div class="flex flex-wrap gap-2 mt-2">
                                    ${data.tags.map(tag => `<span class="px-2 py-1 text-xs bg-white/10 rounded">${tag}</span>`).join('')}
                                </div>
                            </div>
                            ` : ''}
                            
                            ${data.last_campaign_sent ? `
                            <div>
                                <p class="text-white/50 text-sm">Last Campaign</p>
                                <p class="text-white font-medium">${new Date(data.last_campaign_sent).toLocaleDateString()}</p>
                            </div>
                            ` : ''}
                        </div>
                    `;
                    
                    document.getElementById('detailsModal').classList.remove('hidden');
                    document.getElementById('detailsModal').classList.add('flex');
                }
            } catch (error) {
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'Failed to load subscriber details'
                });
            }
        }

        // EXPORT TO EXCEL
        function exportToExcel() {
            const table = document.querySelector('table');
            const ws = XLSX.utils.table_to_sheet(table);
            const wb = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(wb, ws, 'Subscribers');
            XLSX.writeFile(wb, `subscribers_${new Date().toISOString().split('T')[0]}.xlsx`);
        }

        // SEARCH FUNCTIONALITY
        document.getElementById('searchInput').addEventListener('input', function(e) {
            const searchTerm = e.target.value.toLowerCase();
            const rows = document.querySelectorAll('.subscriber-row');
            
            rows.forEach(row => {
                const email = row.querySelector('td:nth-child(2)').textContent.toLowerCase();
                const name = row.querySelector('td:nth-child(3)').textContent.toLowerCase();
                
                if (email.includes(searchTerm) || name.includes(searchTerm)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        });

        // STATUS FILTER
        document.getElementById('statusFilter').addEventListener('change', function(e) {
            const status = e.target.value;
            const rows = document.querySelectorAll('.subscriber-row');
            
            rows.forEach(row => {
                if (status === 'all') {
                    row.style.display = '';
                } else {
                    const rowStatus = row.getAttribute('data-status');
                    row.style.display = rowStatus === status ? '' : 'none';
                }
            });
        });

        // AUTO REFRESH STATS EVERY 30 SECONDS
        setInterval(async () => {
            try {
                const response = await fetch('/api/subscribers/stats');
                const data = await response.json();
                
                if (response.ok) {
                    document.getElementById('totalSubscribers').textContent = data.total.toLocaleString();
                    document.getElementById('activeSubscribers').textContent = data.active.toLocaleString();
                    document.getElementById('unsubscribedCount').textContent = data.unsubscribed.toLocaleString();
                    document.getElementById('avgOpenRate').textContent = data.avg_open_rate.toFixed(1) + '%';
                    
                    // Update growth percentage
                    const growthElement = document.getElementById('subscriberGrowth');
                    if (data.growth > 0) {
                        growthElement.textContent = `+${data.growth}% this month`;
                        growthElement.className = 'flex items-center text-green-400 text-sm';
                    } else {
                        growthElement.textContent = `${data.growth}% this month`;
                        growthElement.className = 'flex items-center text-red-400 text-sm';
                    }
                }
            } catch (error) {
                console.log('Failed to refresh stats:', error);
            }
        }, 30000);
    </script>
</body>
</html>
