    <script>
        // Initialize Charts
        document.addEventListener('DOMContentLoaded', function() {
            // Subscriber Growth Chart
            const subscriberCtx = document.getElementById('subscriberChart').getContext('2d');
            new Chart(subscriberCtx, {
                type: 'line',
                data: {
                    labels: @json($growthLabels),
                    datasets: [{
                        label: 'Subscribers',
                        data: @json($growthData),
                        borderColor: '#3b82f6',
                        backgroundColor: 'rgba(59, 130, 246, 0.1)',
                        tension: 0.4,
                        fill: true
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: {
                            labels: { color: 'white' }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: { color: 'white' },
                            grid: { color: 'rgba(255,255,255,0.1)' }
                        },
                        x: {
                            ticks: { color: 'white' },
                            grid: { color: 'rgba(255,255,255,0.1)' }
                        }
                    }
                }
            });

            // Engagement Chart
            const engagementCtx = document.getElementById('engagementChart').getContext('2d');
            new Chart(engagementCtx, {
                type: 'doughnut',
                data: {
                    labels: ['Opens', 'Clicks', 'No Engagement'],
                    datasets: [{
                        data: [
                            {{ $totalOpens }},
                            {{ $totalClicks }},
                            {{ max(0, $totalSubscribers - $totalOpens) }}
                        ],
                        backgroundColor: ['#3b82f6', '#a855f7', '#374151'],
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: { color: 'white' }
                        }
                    }
                }
            });
        });

        // Live updates
        setInterval(() => {
            fetch('/api/dashboard-stats')
                .then(response => response.json())
                .then(data => {
                    if (data.emailsToday !== undefined) {
                        document.getElementById('emailsToday').textContent = data.emailsToday;
                        document.getElementById('opensToday').textContent = data.opensToday;
                        document.getElementById('clicksToday').textContent = data.clicksToday;
                        document.getElementById('activeCampaigns').textContent = data.activeCampaigns;
                    }
                })
                .catch(error => console.log('Update skipped:', error));
        }, 30000);
    </script>
</body>
